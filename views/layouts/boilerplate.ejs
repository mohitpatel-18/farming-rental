<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= (typeof title !== 'undefined' && title) ? title : 'Farming Rental' %></title>

  <!-- ✅ Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- ✅ Font Awesome Icons -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    crossorigin="anonymous"
    referrerpolicy="no-referrer"
  />

  <!-- 🌾 Background Farming Theme -->
  <style>
    /* Background image + overlay */
    body {
      background: linear-gradient(
          rgba(0, 0, 0, 0.55),
          rgba(0, 0, 0, 0.55)
        ),
        url('/images/farm-image.jpg') no-repeat center center fixed;
      background-size: cover;
      color: white;
      font-family: 'Poppins', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      animation: slowZoom 30s ease-in-out infinite alternate;
    }

    /* Smooth parallax effect */
    @keyframes slowZoom {
      0% { background-size: 100% auto; }
      100% { background-size: 105% auto; }
    }

    /* Navbar */
    nav {
      background-color: rgba(0, 0, 0, 0.85);
      backdrop-filter: blur(6px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    /* Footer */
    footer {
      background-color: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(8px);
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      color: #d1d5db;
      font-size: 0.95rem;
    }

    /* Container */
    .container {
      background: rgba(0, 0, 0, 0.45);
      border-radius: 1rem;
      padding: 1.5rem;
    }

    /* Links + social icons */
    footer a {
      color: #22c55e;
      transition: color 0.2s ease-in-out;
    }
    footer a:hover {
      color: #86efac;
    }
    .social-icons i {
      transition: transform 0.3s, color 0.3s;
    }
    .social-icons i:hover {
      color: #22c55e;
      transform: scale(1.1);
    }
  </style>
</head>

<body>
  <!-- ✅ Navbar -->
  <%- include('../includes/navbar') %>

  <!-- ✅ Main Page Content -->
  <main class="flex-grow">
    <div class="container mx-auto px-4 py-6 mt-4">
      <%- include('../includes/flash') %>
      <%- body %>
    </div>
  </main>

  <!-- ✅ Footer -->
  <footer class="text-gray-300 py-10">
    <div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Left Section -->
      <div>
        <h2 class="text-2xl font-bold text-green-400 mb-3">Farming Rental 🌾</h2>
        <p class="text-sm leading-relaxed text-gray-300">
          Explore endless farming opportunities — rent tractors, farmland, and tools easily.
          Farming Rental empowers communities to grow and share sustainable resources 🌱.
        </p>
      </div>

      <!-- Middle Section -->
      <div>
        <h3 class="text-xl font-semibold text-green-300 mb-3">About This Project</h3>
        <p class="text-sm text-gray-300 leading-relaxed">
          <strong>Farming Rental</strong> bridges the gap between farmers and landowners.
          We make it simple to connect, share, and cultivate better agricultural growth 🚜.
        </p>
      </div>

      <!-- Right Section -->
      <div>
        <h3 class="text-xl font-semibold text-green-300 mb-3">Contact Us</h3>
        <p class="text-sm text-gray-300 mb-2">Have questions or suggestions? Reach out anytime!</p>
        <a href="mailto:mohitpatelpip06@gmail.com" class="text-green-400 hover:text-green-300">
          mohitpatelpip06@gmail.com
        </a>

        <div class="social-icons flex space-x-4 mt-4 text-gray-400">
          <a href="#"><i class="fab fa-facebook text-xl"></i></a>
          <a href="#"><i class="fab fa-twitter text-xl"></i></a>
          <a href="#"><i class="fab fa-instagram text-xl"></i></a>
          <a href="#"><i class="fab fa-linkedin text-xl"></i></a>
        </div>
      </div>
    </div>

    <!-- Bottom Footer -->
    <div class="border-t border-gray-700 mt-8 pt-4 text-center text-gray-400 text-sm">
      © 2025 Farming Rental | Made with ❤️ by <span class="text-green-400 font-medium">Mohit Patel</span>
    </div>
  </footer>
</body>
</html>
