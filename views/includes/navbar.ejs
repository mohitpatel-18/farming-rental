<nav class="bg-[#0b0f17] text-white py-3 shadow-md">
  <div class="container mx-auto flex justify-between items-center px-6">

    <!-- 🌾 Logo / Brand -->
    <div class="logo">
      <a href="/" class="text-2xl font-bold tracking-wide bg-[#111827] px-4 py-2 rounded-xl hover:bg-[#1e293b] transition-all duration-300 shadow-md hover:shadow-blue-500/30">
        Farming Rental 🌿
      </a>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden lg:flex items-center space-x-4">
      <a href="/listings/new" 
         class="bg-[#111827] px-4 py-2 rounded-lg hover:bg-blue-900/40 hover:shadow-[0_0_10px_#2563eb] transition-all duration-300">
         Create Listing
      </a>

      <% 
        var user = (typeof curUser !== 'undefined' && curUser) ? curUser : ((typeof currentUser !== 'undefined' && currentUser) ? currentUser : null);
      %>

      <% if (!user) { %>
        <a href="/login" 
           class="bg-[#111827] px-4 py-2 rounded-lg hover:bg-blue-900/40 hover:shadow-[0_0_10px_#2563eb] transition-all duration-300">
           Login
        </a>

        <a href="/signup" 
           class="bg-[#111827] px-4 py-2 rounded-lg hover:bg-blue-900/40 hover:shadow-[0_0_10px_#2563eb] transition-all duration-300">
           Signup
        </a>
      <% } else { %>
        <span class="bg-[#111827] px-4 py-2 rounded-lg shadow-inner text-blue-400 font-semibold">
          👋 Hello, <%= user.username ? user.username : 'Farmer' %>
        </span>
        <a href="/logout" 
           class="bg-[#111827] px-4 py-2 rounded-lg hover:bg-blue-900/40 hover:shadow-[0_0_10px_#2563eb] transition-all duration-300">
           Logout
        </a>
      <% } %>
    </div>

    <!-- Mobile Menu Button -->
    <div class="lg:hidden">
      <button id="mobile-menu-btn" 
              class="bg-[#111827] px-4 py-2 rounded-lg hover:bg-blue-900/40 hover:shadow-[0_0_10px_#2563eb] transition-all duration-300">
        Menu
      </button>
    </div>
  </div>
</nav>
