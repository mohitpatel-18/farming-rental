<% layout('/layouts/boilerplate') %>

<!-- Page Title -->
<% title = "Farming Tools Listings" %>

<!-- Farming Tools Category Bar -->
<section class="bg-transparent">
  <div class="filtersi flex overflow-x-auto no-scrollbar gap-6 py-3 px-4 border-b border-gray-700 bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 sticky top-0 z-10">

    <% const tools = [
      { icon: "fa-tractor", name: "Tractor" },
      { icon: "fa-screwdriver-wrench", name: "Plough" },
      { icon: "fa-gears", name: "Harvester" },
      { icon: "fa-seedling", name: "Seeder" },
      { icon: "fa-flask", name: "Sprayer" },
      { icon: "fa-droplet", name: "Irrigation" },
      { icon: "fa-toolbox", name: "Cultivator" },
      { icon: "fa-helicopter", name: "Drone" },
      { icon: "fa-sun", name: "Solar" },
      { icon: "fa-truck", name: "Transport" },
      { icon: "fa-hard-hat", name: "Safety" }
    ]; %>

    <% tools.forEach(tool => { %>
      <button class="tool-btn flex flex-col items-center justify-center min-w-[88px] text-center px-2 py-1 text-gray-400 hover:text-green-400 transition">
        <i class="fa-solid <%= tool.icon %> text-2xl mb-1"></i>
        <span class="text-xs font-medium"><%= tool.name %></span>
      </button>
    <% }) %>

    <!-- Taxes toggle -->
    <div id="switch" class="form-switch flex items-center gap-2 ml-4 mt-1">
      <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault" />
      <label class="form-check-label text-gray-300 ml-2" for="flexSwitchCheckDefault">With taxes</label>
      <span class="short-gst text-sm text-gray-400 ml-2">GST</span>
    </div>
  </div>
</section>

<!-- Main Content -->
<section class="py-8">
  <div class="container mx-auto px-4">
    <h1 class="text-4xl font-bold text-center text-green-400 mb-8">Explore All Listings</h1>
    <!-- Your listings will render here -->
  </div>
</section>

<!-- JS for glow click effect -->
<script>
  const buttons = document.querySelectorAll('.tool-btn');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      // remove active class from all
      buttons.forEach(b => b.classList.remove('active-tool'));

      // add active class to clicked one
      btn.classList.add('active-tool');
    });
  });
</script>

<!-- Custom glow styles -->
<style>
  .tool-btn.active-tool {
    color: #60a5fa !important; /* light navy blue text */
    text-shadow: 0 0 10px #1e3a8a, 0 0 20px #1e40af; /* navy glow */
    transform: scale(1.08);
    transition: all 0.25s ease-in-out;
  }

  .tool-btn.active-tool i {
    color: #60a5fa;
  }

  .tool-btn:hover i {
    transform: scale(1.1);
    transition: transform 0.2s;
  }
</style>
